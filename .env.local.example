# SecondMe OAuth
SECONDME_CLIENT_ID=
SECONDME_CLIENT_SECRET=
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback
SECONDME_OAUTH_SCOPES=user.info,chat,user.info.softmemory,note.add

# Optional real-agent slots for PathSplit parallel narratives
# In production, set at least SECONDME_AGENT_FOUNDER_REFRESH_TOKEN
# to guarantee one public "SecondMe Live" narrative card.
SECONDME_AGENT_FOUNDER_REFRESH_TOKEN=
SECONDME_AGENT_STAYED_REFRESH_TOKEN=
SECONDME_AGENT_RETURNED_REFRESH_TOKEN=

# Optional follow-up model override (default: google_ai_studio/gemini-2.0-flash)
SECONDME_FOLLOWUP_MODEL=

# SecondMe API
SECONDME_API_BASE=https://api.mindverse.com/gate/lab

# LLM (DeepSeek or OpenAI-compatible)
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Keep the public demo honest: this should describe the deployed mode, not hide it.
NEXT_PUBLIC_PATHSPLIT_DEMO_MODE=mock

# Optional debug tuning
# PATHSPLIT_AGENT_STAGGER_MS=260
# PATHSPLIT_STREAM_DELAY_MS=220
# PATHSPLIT_FAIL_AGENT_ID=failed-and-returned
